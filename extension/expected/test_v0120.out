-- ─────────────────────────────────────────────────────────────────────────────
SELECT final_state AS pii_ovrd_s
FROM pgmnemo.remember_fact(
    'tc_v0120', 'person:pii_ovrd', 'occupation', 'Engineer',
    0.9, TRUE, NULL, 'system', 99999
);
 pii_ovrd_s 
