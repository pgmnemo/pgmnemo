-- ─────────────────────────────────────────────────────────────────────────────
-- BT7: confidence=0.79 (just below 0.8) → agent_authored → candidate
-- ─────────────────────────────────────────────────────────────────────────────
SELECT final_state AS c079_st
FROM pgmnemo.remember_fact(
    'tc_v0120', 'org:conf_079', 'p', 'v',
    0.79, NULL, NULL, 'agent_authored', 99999
);
  c079_st  
