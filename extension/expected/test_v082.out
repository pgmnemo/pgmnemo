-- =============================================================================
-- Cleanup
-- =============================================================================
DELETE FROM pgmnemo.agent_lesson WHERE role IN ('tc_v082', 'tc_v082_ghost');
-- Restore defaults
SET pgmnemo.include_unverified = 'off';
SET pgmnemo.gate_strict = 'enforce';
