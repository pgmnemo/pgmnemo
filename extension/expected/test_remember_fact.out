-- Function exists with correct schema
SELECT proname = 'guard_no_test_project' AS t16_guard_exists
FROM pg_proc p
JOIN pg_namespace n ON n.oid = p.pronamespace
WHERE n.nspname = 'pgmnemo' AND p.proname = 'guard_no_test_project';
 t16_guard_exists
