-- ─────────────────────────────────────────────────────────────────────────────
-- T3: canonical_slug() — invalid type raises
-- ─────────────────────────────────────────────────────────────────────────────
DO $$
BEGIN
    PERFORM pgmnemo.canonical_slug('human', 'Ada Lovelace');
    RAISE EXCEPTION 'T3 FAIL: expected EXCEPTION, got none';
EXCEPTION
    WHEN OTHERS THEN
        IF SQLERRM LIKE '%invalid type prefix%' THEN
            RAISE NOTICE 'T3 PASS: invalid type prefix rejected';
        ELSE
            RAISE EXCEPTION 'T3 FAIL: wrong error: %', SQLERRM;
        END IF;
END;
$$;
NOTICE:  T3 PASS: invalid type prefix rejected
DO
