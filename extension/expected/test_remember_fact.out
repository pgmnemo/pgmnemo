-- test_remember_fact.sql
-- pg_regress integration tests: pgmnemo v0.12.0 remember_fact() + helpers
-- ADDENDUM-2: 7 correctness requirements
--
-- Coverage:
--   Setup: guard_no_test_project() — confirms test DB context (R6)
--   T1:   _has_contact_pii() — PII property detection (all 5 PII + 2 non-PII)
--   T2:   canonical_slug() — normalisation (person, org, concept, project)
--   T3:   canonical_slug() — invalid type raises EXCEPTION
--   T4:   remember_fact() — fresh INSERT, source_type='system' → validated (R1)
--   T5:   remember_fact() — agent_authored, conf≥0.8, non-PII → validated (R1)
--   T6:   remember_fact() — agent_authored, conf<0.8, non-PII → candidate (R1)
--   T7:   remember_fact() — auto_captured → candidate regardless of confidence (R1)
--   T8a:  remember_fact() — PII email on person:* + system source → candidate ALWAYS (ADR-61 D4)
--   T8b:  remember_fact() — PII phone on person:* → candidate
--   T8c:  remember_fact() — non-PII role on person:* + system source → validated
--   T8d:  remember_fact() — p_has_contact_pii=TRUE overrides auto-detect → candidate (R7)
--   T9:   remember_fact() — NULL embedding accepted (fail-open) (R5)
--   T10:  remember_fact() — artifact_hash synthesized as 'fact-entity:property' in DB (R2)
--   T11:  remember_fact() — MERGE: same value, id unchanged, confidence updated (R3)
--   T12:  remember_fact() — SUPERSEDE: new value, prior closed, version_n incremented (R3)
--   T13:  remember_fact() — cross-role identity: different roles share same (entity+property) (R3)
--   T14:  remember_fact() — ingest_entity compat: version_n=0 prior → new row version_n=1 (R4)
--   T15:  remember_fact() — artifact_hash IS present in DB row (R2 verification)
--   T16:  guard_no_test_project() — passes in test DB (R6)
--
-- Prerequisites: pgmnemo 0.11.1+ installed (upgrade applied in setup block).
-- Test DB: 'regression' (pg_regress default) — in allowed list for guard_no_test_project.
-- Isolation: role 'rf_test' (and rf_test_role_a, rf_test_role_b), project_id=99999.
-- ─────────────────────────────────────────────────────────────────────────────
-- Setup
-- ─────────────────────────────────────────────────────────────────────────────
ALTER EXTENSION pgmnemo UPDATE TO '0.12.0';
NOTICE:  pgmnemo: upgrading to version 0.12.0 (Typed Write API)
ALTER EXTENSION
SET pgmnemo.gate_strict          = 'off';
SET
SET pgmnemo.include_unverified   = 'on';
SET
SET pgmnemo.track_recall_recency = 'off';
SET
-- R6: guard verifies we are NOT in a prod database
SELECT pgmnemo.guard_no_test_project(99999);
 guard_no_test_project
-----------------------

(1 row)

-- ─────────────────────────────────────────────────────────────────────────────
-- T1: _has_contact_pii() — PII property closed-set detection
-- ─────────────────────────────────────────────────────────────────────────────
-- T1a: all five PII properties return TRUE
SELECT
    pgmnemo._has_contact_pii('email')     AS email_pii,
    pgmnemo._has_contact_pii('phone')     AS phone_pii,
    pgmnemo._has_contact_pii('address')   AS address_pii,
    pgmnemo._has_contact_pii('telegram')  AS telegram_pii,
    pgmnemo._has_contact_pii('full_name') AS full_name_pii;
 email_pii | phone_pii | address_pii | telegram_pii | full_name_pii
-----------+-----------+-------------+--------------+---------------
 t         | t         | t           | t            | t
(1 row)

-- T1b: non-PII properties return FALSE
SELECT
    pgmnemo._has_contact_pii('role')        AS role_not_pii,
    pgmnemo._has_contact_pii('affiliation') AS aff_not_pii,
    pgmnemo._has_contact_pii('status')      AS status_not_pii;
 role_not_pii | aff_not_pii | status_not_pii
--------------+-------------+----------------
 f            | f           | f
(1 row)

