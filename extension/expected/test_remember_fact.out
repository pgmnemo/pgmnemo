-- ─────────────────────────────────────────────────────────────────────────────
-- T10: artifact_hash synthesized as 'fact-<entity_key>:<property>' in DB (R2)
-- ─────────────────────────────────────────────────────────────────────────────
SELECT
    al.artifact_hash IS NOT NULL              AS t10_hash_non_null,
    al.artifact_hash = 'fact-project:pgmnemo:version' AS t10_hash_format
FROM pgmnemo.remember_fact(
    p_role        => 'rf_test',
    p_entity_key  => 'project:pgmnemo',
    p_property    => 'version',
    p_value       => '0.12.0',
    p_confidence  => 0.99,
    p_source_type => 'system',
    p_project_id  => 99999
) rf
JOIN pgmnemo.agent_lesson al ON al.id = rf.id;
 t10_hash_non_null | t10_hash_format
-------------------+-----------------
 t                 | t
(1 row)

-- ─────────────────────────────────────────────────────────────────────────────
-- T11: MERGE — same value: id unchanged, confidence updated, state re-classified (R3)
-- ─────────────────────────────────────────────────────────────────────────────
DO $$
DECLARE
    _id1 BIGINT; _id2 BIGINT; _conf REAL; _state TEXT;
BEGIN
    SELECT id INTO _id1
    FROM pgmnemo.remember_fact('rf_test','org:acme','founded','1990-01-01',
                               0.6, NULL, NULL, 'agent_authored', 99999, NULL, NULL);

    SELECT id INTO _id2
    FROM pgmnemo.remember_fact('rf_test','org:acme','founded','1990-01-01',
                               0.9, NULL, NULL, 'system', 99999, NULL, NULL);

    SELECT confidence, state INTO _conf, _state
    FROM pgmnemo.agent_lesson WHERE id = _id1;

    IF _id1 <> _id2 THEN
        RAISE EXCEPTION 'T11 FAIL: MERGE created a new row (id1=%, id2=%)', _id1, _id2;
    END IF;
    IF _conf < 0.9 THEN
        RAISE EXCEPTION 'T11 FAIL: confidence not upgraded (got %)', _conf;
    END IF;
    IF _state <> 'validated' THEN
        RAISE EXCEPTION 'T11 FAIL: state not reclassified (got %)', _state;
    END IF;
    RAISE NOTICE 'T11 PASS: MERGE id=%, conf=%, state=%', _id1, _conf, _state;
END;
$$;
NOTICE:  T11 PASS: MERGE state=validated
DO
-- ─────────────────────────────────────────────────────────────────────────────
-- T12: SUPERSEDE — different value: prior closed, new row, version_n incremented (R3)
-- ─────────────────────────────────────────────────────────────────────────────
DO $$
DECLARE
    _id1 BIGINT; _id2 BIGINT;
    _prior_state TEXT; _prior_valid_to TIMESTAMPTZ;
    _new_ver INT; _prior_ver INT;
BEGIN
    SELECT id INTO _id1
    FROM pgmnemo.remember_fact('rf_test','org:acme','ceo','Alice Smith',
                               0.85, NULL, NULL, 'agent_authored', 99999, NULL, NULL);

    SELECT id INTO _id2
    FROM pgmnemo.remember_fact('rf_test','org:acme','ceo','Bob Jones',
                               0.9, NULL, NULL, 'agent_authored', 99999, NULL, NULL);

    SELECT state, t_valid_to, version_n INTO _prior_state, _prior_valid_to, _prior_ver
    FROM pgmnemo.agent_lesson WHERE id = _id1;

    SELECT version_n INTO _new_ver FROM pgmnemo.agent_lesson WHERE id = _id2;

    IF _id1 = _id2 THEN
        RAISE EXCEPTION 'T12 FAIL: expected new row, got same id=%', _id1;
    END IF;
    IF _prior_state <> 'superseded' THEN
        RAISE EXCEPTION 'T12 FAIL: prior state=% (expected superseded)', _prior_state;
    END IF;
    IF _prior_valid_to = 'infinity'::TIMESTAMPTZ THEN
        RAISE EXCEPTION 'T12 FAIL: prior t_valid_to still infinity';
    END IF;
    IF _new_ver <> _prior_ver + 1 THEN
        RAISE EXCEPTION 'T12 FAIL: version_n % ≠ prior % + 1', _new_ver, _prior_ver;
    END IF;
    RAISE NOTICE 'T12 PASS: SUPERSEDE prior_id=%, new_id=%, prior_v=%, new_v=%',
        _id1, _id2, _prior_ver, _new_ver;
END;
$$;
NOTICE:  T12 PASS: SUPERSEDE prior_v=1, new_v=2
DO
-- ─────────────────────────────────────────────────────────────────────────────
-- T13: cross-role identity: (lower(entity_key/property), project_id), NOT role (R3)
-- ─────────────────────────────────────────────────────────────────────────────
DO $$
DECLARE
    _id_a BIGINT; _id_b BIGINT; _active_count BIGINT; _prior_state TEXT;
BEGIN
    SELECT id INTO _id_a
    FROM pgmnemo.remember_fact('rf_test_role_a','concept:distributed_systems','definition',
        'Original definition written by role A.',
        0.9, NULL, NULL, 'agent_authored', 99999, NULL, NULL);

    SELECT id INTO _id_b
    FROM pgmnemo.remember_fact('rf_test_role_b','concept:distributed_systems','definition',
        'Updated definition written by role B — overrides role A.',
        0.95, NULL, NULL, 'agent_authored', 99999, NULL, NULL);

    SELECT state INTO _prior_state FROM pgmnemo.agent_lesson WHERE id = _id_a;

    SELECT COUNT(*) INTO _active_count
    FROM pgmnemo.agent_lesson
    WHERE lower(topic) = 'concept:distributed_systems/definition'
      AND content_type = 'fact'
      AND project_id = 99999
      AND is_active
      AND t_valid_to = 'infinity'::TIMESTAMPTZ;

    IF _id_a = _id_b THEN
        RAISE EXCEPTION 'T13 FAIL: expected supersession, got merge (same id)';
    END IF;
    IF _prior_state <> 'superseded' THEN
        RAISE EXCEPTION 'T13 FAIL: role_a row state=% (expected superseded)', _prior_state;
    END IF;
    IF _active_count <> 1 THEN
        RAISE EXCEPTION 'T13 FAIL: active_count=% (expected 1)', _active_count;
    END IF;
    RAISE NOTICE 'T13 PASS: cross-role supersession: role_a_id=%, role_b_id=%, active=%',
        _id_a, _id_b, _active_count;
END;
$$;
NOTICE:  T13 PASS: cross-role supersession, active=1
DO
-- ─────────────────────────────────────────────────────────────────────────────
-- T14: ingest_entity compat — version_n=0 prior yields version_n=1 on first typed write (R4)
-- ─────────────────────────────────────────────────────────────────────────────
-- Simulate a pre-migration ingest_entity row (version_n=0 sentinel)
INSERT INTO pgmnemo.agent_lesson (
    role, project_id, topic, lesson_text,
    content_type, state, verified_at, artifact_hash, version_n
) VALUES (
    'rf_test', 99999,
    'org:legacy_corp/founded',
    'org:legacy_corp founded: 1985-01-01',
    'fact', 'validated', NOW(),
    'fact-org:legacy_corp:founded',
    0   -- pre-migration sentinel (PROPERTY_CONVENTIONS §ingest_entity compat)
);
INSERT 0 1
DO $$
DECLARE
    _new_id BIGINT; _new_ver INT;
BEGIN
    SELECT id INTO _new_id
    FROM pgmnemo.remember_fact('rf_test','org:legacy_corp','founded','1986-01-01',
                               0.9, NULL, NULL, 'system', 99999, NULL, NULL);

    SELECT version_n INTO _new_ver FROM pgmnemo.agent_lesson WHERE id = _new_id;

    IF _new_ver <> 1 THEN
        RAISE EXCEPTION 'T14 FAIL: version_n=% (expected 1 for first typed write over v_n=0)', _new_ver;
    END IF;
    RAISE NOTICE 'T14 PASS: first typed write over ingest_entity row: version_n=%', _new_ver;
END;
$$;
NOTICE:  T14 PASS: first typed write over ingest_entity row: version_n=1
DO
-- ─────────────────────────────────────────────────────────────────────────────
-- T15: artifact_hash IS present in DB row (R2 — synthesized, non-NULL) (R2)
-- ─────────────────────────────────────────────────────────────────────────────
SELECT
    al.artifact_hash IS NOT NULL          AS t15_hash_present,
    al.artifact_hash LIKE 'fact-%'        AS t15_hash_format_ok
FROM pgmnemo.remember_fact(
    p_role        => 'rf_test',
    p_entity_key  => 'project:pgmnemo',
    p_property    => 'status',
    p_value       => 'active',
    p_confidence  => 0.95,
    p_source_type => 'system',
    p_project_id  => 99999
) rf
JOIN pgmnemo.agent_lesson al ON al.id = rf.id;
 t15_hash_present | t15_hash_format_ok
------------------+--------------------
 t                | t
(1 row)

