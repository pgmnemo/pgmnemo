-- test_confidence.sql
-- pg_regress tests for pgmnemo v0.7.0 outcome-learning loop
--
-- Coverage:
--   T1: confidence column default (0.5) and CHECK constraint (< 0, > 1 rejected)
--   T2: reinforce() success path  (+0.10, stays in [0.55, 0.65])
--   T3: reinforce() failure path  (-0.15, stays in [0.30, 0.40])
--   T4: reinforce() neutral       (no change, returns 0.5)
--   T5: reinforce() boundary clamping (0.95 → 1.0; 0.10 → 0.0)
--   T6: recall_lessons() ranks high-confidence lesson above low-confidence
--   T7: footgun NOTICE fires on NULL embedding with text query
--   T8: ingest() guards (F1 min-length, F2 repetition)
--   T9: stats() confidence distribution columns present and in-range
-- Prerequisites: pgmnemo 0.7.0 installed.
-- gate_strict=off: insert test rows without commit_sha/artifact_hash.
-- include_unverified=on: recall unverified test rows.
SET pgmnemo.gate_strict = 'off';
SET pgmnemo.include_unverified = 'on';
-- =============================================================================
-- T1: confidence column default and CHECK constraint
-- =============================================================================
-- T1a: INSERT without explicit confidence → DEFAULT 0.5
INSERT INTO pgmnemo.agent_lesson (role, topic, lesson_text)
VALUES ('tc_v070', 'confidence_default', 'default confidence value test lesson text here')
RETURNING confidence = 0.5 AS default_is_half;
 default_is_half 
-----------------
 t
(1 row)

-- T1b: CHECK rejects confidence < 0.0
DO $$
BEGIN
    INSERT INTO pgmnemo.agent_lesson (role, topic, lesson_text, confidence)
    VALUES ('tc_v070', 'ck_low', 'confidence below zero check constraint test lesson', -0.01);
    RAISE EXCEPTION 'T1b FAIL: CHECK did not fire';
EXCEPTION WHEN check_violation THEN
    RAISE NOTICE 'T1b PASS: confidence<0 rejected';
END;
$$;
NOTICE:  T1b PASS: confidence<0 rejected
-- T1c: CHECK rejects confidence > 1.0
DO $$
BEGIN
    INSERT INTO pgmnemo.agent_lesson (role, topic, lesson_text, confidence)
    VALUES ('tc_v070', 'ck_high', 'confidence above one check constraint test lesson here', 1.01);
    RAISE EXCEPTION 'T1c FAIL: CHECK did not fire';
EXCEPTION WHEN check_violation THEN
    RAISE NOTICE 'T1c PASS: confidence>1 rejected';
END;
$$;
NOTICE:  T1c PASS: confidence>1 rejected
-- =============================================================================
-- T2: reinforce() success path (+0.10, clamped, increments success_count)
-- =============================================================================
WITH ins AS (
    INSERT INTO pgmnemo.agent_lesson (role, topic, lesson_text)
    VALUES ('tc_v070', 'reinforce_success',
            'reinforce success outcome confidence update integration test lesson')
    RETURNING id
),
reinforced AS (
    SELECT pgmnemo.reinforce(id, 'success') AS new_conf FROM ins
)
SELECT new_conf > 0.55 AND new_conf < 0.65 AS success_confidence_raised FROM reinforced;
 success_confidence_raised 
---------------------------
 t
(1 row)

-- =============================================================================
-- T3: reinforce() failure path (-0.15, clamped, increments fail_count)
-- =============================================================================
WITH ins AS (
    INSERT INTO pgmnemo.agent_lesson (role, topic, lesson_text)
    VALUES ('tc_v070', 'reinforce_failure',
            'reinforce failure outcome confidence update integration test lesson')
    RETURNING id
),
reinforced AS (
    SELECT pgmnemo.reinforce(id, 'failure') AS new_conf FROM ins
)
SELECT new_conf > 0.30 AND new_conf < 0.40 AS failure_confidence_lowered FROM reinforced;
 failure_confidence_lowered 
----------------------------
 t
(1 row)

-- =============================================================================
-- T4: reinforce() neutral (no-op, returns unchanged confidence)
-- =============================================================================
WITH ins AS (
    INSERT INTO pgmnemo.agent_lesson (role, topic, lesson_text)
    VALUES ('tc_v070', 'reinforce_neutral',
            'reinforce neutral outcome confidence unchanged integration test lesson')
    RETURNING id
),
reinforced AS (
    SELECT pgmnemo.reinforce(id, 'neutral') AS new_conf FROM ins
)
SELECT new_conf = 0.5 AS neutral_confidence_unchanged FROM reinforced;
 neutral_confidence_unchanged 
------------------------------
 t
(1 row)

-- =============================================================================
-- T5a: reinforce() upper boundary: 0.95 + success → clamped to 1.0
-- =============================================================================
WITH ins AS (
    INSERT INTO pgmnemo.agent_lesson (role, topic, lesson_text, confidence)
    VALUES ('tc_v070', 'reinforce_clamp_high',
            'reinforce boundary clamp upper confidence test lesson text here', 0.95)
    RETURNING id
),
reinforced AS (
    SELECT pgmnemo.reinforce(id, 'success') AS new_conf FROM ins
)
SELECT new_conf = 1.0 AS clamped_to_one FROM reinforced;
 clamped_to_one 
----------------
 t
(1 row)

-- T5b: reinforce() lower boundary: 0.10 + failure → clamped to 0.0
WITH ins AS (
    INSERT INTO pgmnemo.agent_lesson (role, topic, lesson_text, confidence)
    VALUES ('tc_v070', 'reinforce_clamp_low',
            'reinforce boundary clamp lower confidence test lesson text here', 0.10)
    RETURNING id
),
reinforced AS (
    SELECT pgmnemo.reinforce(id, 'failure') AS new_conf FROM ins
)
SELECT new_conf = 0.0 AS clamped_to_zero FROM reinforced;
 clamped_to_zero 
-----------------
 t
(1 row)

-- =============================================================================
-- T6: recall_lessons() ranks high-confidence lesson above low-confidence
--     (vector-only path with NULL embedding; tie-broken by confidence term)
-- =============================================================================
INSERT INTO pgmnemo.agent_lesson (role, topic, lesson_text, confidence)
VALUES ('tc_v070', 'recall_confidence_high',
        'confidence ranking recall test high confidence lesson text', 0.9);
INSERT INTO pgmnemo.agent_lesson (role, topic, lesson_text, confidence)
VALUES ('tc_v070', 'recall_confidence_low',
        'confidence ranking recall test low confidence lesson text', 0.1);
-- The NOTICE fires because query_embedding IS NULL.
-- High-confidence (0.9) scores +0.135 vs low-confidence (0.1) +0.015 in confidence term.
SELECT confidence > 0.5 AS top_result_is_high_confidence
FROM pgmnemo.recall_lessons(
    NULL::vector(1024),
    1,
    'tc_v070',
    NULL,
    'confidence ranking recall test'
)
LIMIT 1;
NOTICE:  pgmnemo: query_embedding IS NULL -- falling back to text-only recall; no semantic similarity
 top_result_is_high_confidence 
-------------------------------
 t
(1 row)

-- =============================================================================
-- T7: footgun NOTICE fires when recall_hybrid called with NULL embedding + text
-- =============================================================================
SELECT COUNT(*) >= 0 AS recall_hybrid_text_only_runs
FROM pgmnemo.recall_hybrid(
    NULL::vector(1024),
    'footgun notice test hybrid recall text query',
    1,
    'tc_v070',
    NULL
);
NOTICE:  pgmnemo: query_embedding IS NULL -- falling back to text-only recall; no semantic similarity
NOTICE:  pgmnemo: 8 matching lesson(s) are unverified (ingested without commit_sha/artifact_hash) and excluded by default. SET pgmnemo.include_unverified = 'on' for this session, or pass provenance on ingest.
 recall_hybrid_text_only_runs 
------------------------------
 t
(1 row)

-- =============================================================================
-- T8: ingest() guards
-- F1: lesson_text < 20 chars → RAISE EXCEPTION
-- F2: repetitive content (>80% most-frequent token) → RAISE EXCEPTION
-- =============================================================================
-- F1: min-length guard
DO $$
BEGIN
    PERFORM pgmnemo.ingest('tc_v070', 999, 'topic', 'too short');
    RAISE EXCEPTION 'F1 FAIL: min-length guard did not fire';
EXCEPTION WHEN OTHERS THEN
    IF SQLERRM LIKE '%lesson_text too short (min 20 chars)%' THEN
        RAISE NOTICE 'F1 PASS: min-length guard fired';
    ELSE
        RAISE EXCEPTION 'F1 FAIL: unexpected error: %', SQLERRM;
    END IF;
END;
$$;
NOTICE:  F1 PASS: min-length guard fired
-- F2: repetition guard (single token repeated >80% of all tokens)
DO $$
BEGIN
    PERFORM pgmnemo.ingest('tc_v070', 999, 'topic',
        'spam spam spam spam spam spam spam spam spam spam spam');
    RAISE EXCEPTION 'F2 FAIL: repetition guard did not fire';
EXCEPTION WHEN OTHERS THEN
    IF SQLERRM LIKE '%repetitive content%' THEN
        RAISE NOTICE 'F2 PASS: repetition guard fired';
    ELSE
        RAISE EXCEPTION 'F2 FAIL: unexpected error: %', SQLERRM;
    END IF;
END;
$$;
NOTICE:  F2 PASS: repetition guard fired
-- =============================================================================
-- T9: stats() confidence distribution columns present and in valid range
-- =============================================================================
SELECT
    confidence_mean  BETWEEN 0.0 AND 1.0 AS mean_in_range,
    confidence_p10   BETWEEN 0.0 AND 1.0 AS p10_in_range,
    confidence_p50   BETWEEN 0.0 AND 1.0 AS p50_in_range,
    confidence_p90   BETWEEN 0.0 AND 1.0 AS p90_in_range,
    confidence_below_threshold_count >= 0  AS threshold_count_nonneg
FROM pgmnemo.stats();
 mean_in_range | p10_in_range | p50_in_range | p90_in_range | threshold_count_nonneg 
---------------+--------------+--------------+--------------+------------------------
 t             | t            | t            | t            | t
(1 row)

-- =============================================================================
-- Cleanup
-- =============================================================================
DELETE FROM pgmnemo.agent_lesson WHERE role = 'tc_v070';
