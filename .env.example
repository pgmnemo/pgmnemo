# pgmnemo local environment — template
# Copy to .env and fill in real values. .env is gitignored.

# PGXN manager credentials — for release tooling (manual upload + CI)
# Register at https://manager.pgxn.org
PGXN_USERNAME=your_pgxn_username
PGXN_PASSWORD=your_pgxn_password

# Local Docker bench DB (`docker run pgmnemo-bench ...`)
# Default values match the standard bench container setup.
PGMNEMO_DSN=host=localhost port=15432 dbname=bench user=bench password=bench
