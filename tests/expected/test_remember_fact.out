FROM pgmnemo.remember_fact(
    'tc_rmf', 'person:ada_lovelace', 'affiliation', 'Babbage Institute',
    0.9, NULL, NULL, 'system', 99999
);
 sys_nonpii_state 
------------------
 validated
(1 row)

