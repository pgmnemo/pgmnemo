-- ─────────────────────────────────────────────────────────────────────────────
SELECT pgmnemo.canonical_slug('person', 'Ada Lovelace') AS slug_person;
 slug_person
---------------------
 person:ada_lovelace
(1 row)

SELECT pgmnemo.canonical_slug('org', 'ACME Corp.')      AS slug_org;
