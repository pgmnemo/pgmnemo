---------------
 org:acme_corp
(1 row)

-- ─────────────────────────────────────────────────────────────────────────────
-- T7: guard_no_test_project — blocks IDs <= 100
-- ─────────────────────────────────────────────────────────────────────────────
DO $$
BEGIN
    PERFORM pgmnemo.guard_no_test_project(42);
    RAISE NOTICE 'UNEXPECTED: project_id=42 not blocked';
EXCEPTION WHEN OTHERS THEN
    RAISE NOTICE 'guard_ok: blocked project_id=42 (<=100)';
END;
$$;
NOTICE:  guard_ok: blocked project_id=42 (<=100)
DO
-- ─────────────────────────────────────────────────────────────────────────────
-- T8: guard_no_test_project — allows IDs > 100
-- ─────────────────────────────────────────────────────────────────────────────
DO $$
BEGIN
    PERFORM pgmnemo.guard_no_test_project(99999);
    RAISE NOTICE 'guard_ok: allowed project_id=99999 (>100)';
EXCEPTION WHEN OTHERS THEN
    RAISE NOTICE 'UNEXPECTED: blocked project_id=99999: %', SQLERRM;
END;
$$;
NOTICE:  guard_ok: allowed project_id=99999 (>100)
DO
-- ─────────────────────────────────────────────────────────────────────────────
-- T9: PII routing — person:* + email + system source → candidate ALWAYS (R1/ADR-61 D4)
-- ─────────────────────────────────────────────────────────────────────────────
SELECT final_state AS pii_sys_state
FROM pgmnemo.remember_fact(
    'tc_rmf',
    'person:ada_lovelace',
    'email',
    'ada@example.com',
    0.95,      -- high confidence (would be validated if not PII)
    NULL,      -- auto-detect PII
    NULL,      -- no embedding
    'system',  -- system source → normally validated; PII overrides to candidate
    99999      -- test project_id
);
 pii_sys_state 
---------------
 candidate
(1 row)

