-- test_remember_fact.sql
-- pg_regress tests for pgmnemo v0.12.0: Typed Write API
-- RFC-001 §D2 + ADDENDUM-2 (7 correctness requirements)
--
-- Coverage:
--   T1:  remember_fact signature: 11 params
--   T2:  remember_event signature: 11 params
--   T3:  remember_relation signature: 10 params
--   T4:  _has_contact_pii — PII closed set returns TRUE
--   T5:  _has_contact_pii — non-PII returns FALSE
--   T6:  canonical_slug normalisation (person, org)
--   T7:  guard_no_test_project blocks project_id=42 (<=100)
--   T8:  guard_no_test_project allows project_id=99999 (>100)
--   T9:  remember_fact PII routing: person:* + email + system → candidate ALWAYS
--   T10: remember_fact state: system + non-PII → validated
--   T11: remember_fact state: agent_authored conf>=0.8, non-PII → validated
--   T12: remember_fact state: agent_authored conf<0.8 → candidate
--   T13: remember_fact state: auto_captured → candidate
--   T14: remember_fact artifact_hash synthesized non-NULL (COALESCE; R2)
--   T15: remember_fact dedup/merge — same value → same row id returned (R3)
--   T16: remember_fact supersession — different value → prior superseded, new version (R3)
--   T17: remember_fact NULL embedding → fail-open (write succeeds) (R5)
--   T18: remember_event returns positive id; content_type=event
--   T19: remember_relation idempotent on triple; content_type=relation
--   T20: verified_at gate — validated→NOT NULL (visible); candidate (PII)→NULL (ghost)
--
-- Role 'tc_rmf' isolates this test's data from all other tests.
-- Project_id 99999 (>100) passes guard_no_test_project.
-- gate_strict off: bypass provenance gate for isolated testing.
SET pgmnemo.gate_strict = 'off';
SET pgmnemo.include_unverified = 'on';
SET pgmnemo.track_recall_recency = 'off';
ALTER EXTENSION pgmnemo UPDATE TO '0.12.0';
NOTICE:  version "0.12.0" of extension "pgmnemo" is already installed
-- ─────────────────────────────────────────────────────────────────────────────
-- T1: remember_fact has 11 parameters
-- ─────────────────────────────────────────────────────────────────────────────
SELECT count(*) = 1 AS rf_sig_ok
FROM pg_proc p JOIN pg_namespace n ON n.oid = p.pronamespace
WHERE n.nspname = 'pgmnemo' AND p.proname = 'remember_fact' AND p.pronargs = 11;
 rf_sig_ok 
-----------
 t
(1 row)

-- ─────────────────────────────────────────────────────────────────────────────
-- T2: remember_event has 11 parameters
-- ─────────────────────────────────────────────────────────────────────────────
SELECT count(*) = 1 AS re_sig_ok
FROM pg_proc p JOIN pg_namespace n ON n.oid = p.pronamespace
WHERE n.nspname = 'pgmnemo' AND p.proname = 'remember_event' AND p.pronargs = 11;
 re_sig_ok 
-----------
 t
(1 row)

-- ─────────────────────────────────────────────────────────────────────────────
-- T3: remember_relation has 10 parameters
-- ─────────────────────────────────────────────────────────────────────────────
SELECT count(*) = 1 AS rr_sig_ok
FROM pg_proc p JOIN pg_namespace n ON n.oid = p.pronamespace
WHERE n.nspname = 'pgmnemo' AND p.proname = 'remember_relation' AND p.pronargs = 10;
 rr_sig_ok 
-----------
 t
(1 row)

-- ─────────────────────────────────────────────────────────────────────────────
-- T4: _has_contact_pii — PII properties return TRUE
-- ─────────────────────────────────────────────────────────────────────────────
SELECT
    pgmnemo._has_contact_pii('email')     AS email_pii,
    pgmnemo._has_contact_pii('phone')     AS phone_pii,
    pgmnemo._has_contact_pii('full_name') AS fn_pii,
    pgmnemo._has_contact_pii('address')   AS addr_pii,
    pgmnemo._has_contact_pii('telegram')  AS tg_pii;
 email_pii | phone_pii | fn_pii | addr_pii | tg_pii 
-----------+-----------+--------+----------+--------
 t         | t         | t      | t        | t
(1 row)

-- ─────────────────────────────────────────────────────────────────────────────
-- T5: _has_contact_pii — non-PII properties return FALSE
-- ─────────────────────────────────────────────────────────────────────────────
SELECT
    pgmnemo._has_contact_pii('affiliation') AS aff_pii,
    pgmnemo._has_contact_pii('occupation')  AS occ_pii;
 aff_pii | occ_pii 
---------+---------
 f       | f
(1 row)

-- ─────────────────────────────────────────────────────────────────────────────
