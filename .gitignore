# PostgreSQL extension build artifacts
*.o
*.so
*.dylib
*.dll
*.bc
*.lo
*.a

# pgxs build outputs (extension/results/ is OUTPUT, sql/ and expected/ are TEST FIXTURES — track them)
# Note: benchmarks/*/results/ ARE tracked (TACTICS R8: benchmark files are first-class repo assets)
extension/results/
tmp_check/
log/
*.log

# editor files
.idea/
.vscode/
*.swp
*~
.DS_Store

# Python (used in tooling/benchmarks/scripts only — extension itself is pure SQL)
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/

# Node (used only for MCP server in Variant 2 if/when it ships)
node_modules/

# secrets — never check these in
.env
.env.*
!.env.example
*.pem
*.key

# local benchmark data
benchmarks/data/
benchmarks/results/

# pg_regress outputs
extension/regression.diffs
extension/regression.out

# Internal working documents (process, WG, agent prompts, early ADRs)
spec/
research/
design/
*.zip
.embed_cache/

# pgmnemo.com local backups
index-*.html.bak
.claude/
